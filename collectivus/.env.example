# Reference environment for `docker compose up`. Copy to `.env`, fill in
# every value, then start: `docker compose up -d`. All five variables are
# required — compose will refuse to start with empty substitutions or the
# server will reject the config at boot.
#
# Generate secrets with a CSPRNG, e.g. `openssl rand -hex 32` (64 hex chars
# = 32 bytes). Anything below 32 bytes is rejected by the config validator.
# Treat this file as you would treat private keys: never commit `.env`.
#
# Production deployments MUST terminate TLS in front of both services. The
# admin endpoint and the rendezvous registration endpoint each accept
# bearer tokens; both are vulnerable to passive interception over plain
# HTTP. Caddy, nginx, or Traefik in front of `central:8788` and
# `rendezvous:8789` is the supported pattern.

# Bearer token authorized for POST /v1/admin/invites. The CLI flow
# (`ctvs admin configure --admin-token <token> ...` then
# `ctvs invite create ...`) sends this in the Authorization header.
# Minimum 32 bytes. Rotate by updating both the server env and every
# operator's saved admin config.
COLLECTIVUS_ADMIN_TOKEN=

# HMAC secret the server uses to sign gateway JWTs. Rotating it forces
# every gateway to re-bootstrap, so treat it as long-lived. Minimum 32
# bytes.
COLLECTIVUS_IDENTITY_SECRET=

# Shared bearer token the central server uses to register invites with
# rendezvous AND that the rendezvous service requires on every registration
# request. Must match on both sides — compose passes the same value into
# both containers.
COLLECTIVUS_RENDEZVOUS_REGISTRATION_TOKEN=

# Public URL of the rendezvous service. Used in two places: (1) the
# central server POSTs registrations here, so it must be reachable from
# inside the central container, and (2) it is baked into the `ctvs join`
# command returned in invite responses, so it must also be reachable by
# end users. Typically the public HTTPS URL of a reverse proxy fronting
# port 8789 (e.g. https://rendezvous.example.com).
COLLECTIVUS_RENDEZVOUS_URL=

# Public URL of the central server, baked into invite responses as the
# `--config-endpoint` argument of `npx collectivus join`. Reverse proxy
# this to port 8788 (e.g. https://collectivus.example.com).
COLLECTIVUS_PUBLIC_URL=

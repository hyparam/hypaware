{
  "version": 1,
  "proxy": {
    "listen": "127.0.0.1:8787",
    "upstreams": [
      {
        "name": "openai",
        "base_url": "https://api.openai.com",
        "match": { "path_prefix": "/v1" }
      }
    ],
    "redact_headers": [
      "authorization",
      "x-api-key",
      "anthropic-api-key",
      "cookie",
      "set-cookie"
    ]
  },
  "sink": {
    "type": "file",
    "dir": "./collectivus-data"
  }
}

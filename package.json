{
  "name": "hypaware",
  "version": "0.2.0",
  "type": "module",
  "description": "HypAware: modular logs and telemetry collector with a plugin kernel. Captures Claude Code, Codex, OTEL, and raw AI gateway traffic locally, queryable from a single CLI.",
  "bin": {
    "hypaware": "./bin/hypaware.js",
    "hyp": "./bin/hypaware.js"
  },
  "exports": {
    ".": "./src/core/index.js",
    "./core": "./src/core/index.js",
    "./core/observability": "./src/core/observability/index.js",
    "./core/sinks": "./src/core/sinks/index.js"
  },
  "imports": {
    "#core/observability": "./src/core/observability/index.js"
  },
  "files": [
    "bin/",
    "src/",
    "hypaware-core/",
    "collectivus-plugin-kernel-types.d.ts"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "smoke": "node ./hypaware-core/smoke/index.js"
  },
  "dependencies": {
    "hyparquet": "^1.25.8",
    "hyparquet-compressors": "^1.1.1",
    "icebird": "^0.7.0",
    "squirreling": "^0.12.19"
  },
  "optionalDependencies": {
    "hyparquet-writer": "^0.15.1"
  }
}

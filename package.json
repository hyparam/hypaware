{
  "name": "hypaware",
  "version": "0.2.3",
  "type": "module",
  "description": "HypAware: modular logs and telemetry collector with a plugin kernel. Captures Claude Code, Codex, OTEL, and raw AI gateway traffic locally, queryable from a single CLI.",
  "bin": {
    "hypaware": "./bin/hypaware.js",
    "hyp": "./bin/hypaware.js"
  },
  "exports": {
    ".": "./src/core/index.js",
    "./core": "./src/core/index.js",
    "./core/observability": "./src/core/observability/index.js",
    "./core/sinks": "./src/core/sinks/index.js"
  },
  "imports": {
    "#core/observability": "./src/core/observability/index.js"
  },
  "files": [
    "bin/",
    "src/",
    "hypaware-core/",
    "collectivus-plugin-kernel-types.d.ts"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "node scripts/check-syntax.js",
    "test": "node --test test/**/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke": "node ./hypaware-core/smoke/index.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1053.0",
    "@aws-sdk/credential-provider-ini": "3.972.43",
    "hyparquet": "1.26.0",
    "hyparquet-compressors": "1.1.1",
    "icebird": "0.8.5",
    "squirreling": "0.12.20"
  },
  "optionalDependencies": {
    "hyparquet-writer": "0.15.2"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "typescript": "6.0.3"
  }
}

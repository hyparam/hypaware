{
  "name": "hypaware",
  "version": "1.18.0",
  "type": "module",
  "description": "HypAware: modular logs and telemetry collector with a plugin kernel. Captures Claude Code, Codex, OTEL, and raw AI gateway traffic locally, queryable from a single CLI.",
  "bin": {
    "hypaware": "./bin/hypaware.js",
    "hyp": "./bin/hypaware.js"
  },
  "types": "./src/core/index.d.ts",
  "exports": {
    ".": { "types": "./src/core/index.d.ts", "import": "./src/core/index.js" },
    "./core": { "types": "./src/core/index.d.ts", "import": "./src/core/index.js" },
    "./core/observability": { "types": "./types/core/observability/index.d.ts", "import": "./src/core/observability/index.js" },
    "./core/sinks": { "types": "./types/core/sinks/index.d.ts", "import": "./src/core/sinks/index.js" },
    "./core/query": { "types": "./types/core/query/index.d.ts", "import": "./src/core/query/index.js" },
    "./core/util": { "types": "./types/core/util/index.d.ts", "import": "./src/core/util/index.js" },
    "./integration": { "types": "./src/core/cli/integration.d.ts", "import": "./src/core/cli/integration.js" },
    "./tui": { "types": "./types/core/cli/tui/index.d.ts", "import": "./src/core/cli/tui/index.js" }
  },
  "imports": {
    "#core/observability": "./src/core/observability/index.js"
  },
  "files": [
    "bin/",
    "src/",
    "hypaware-core/",
    "types/",
    "hypaware-plugin-kernel-types.d.ts"
  ],
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "test": "node scripts/run-tests.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:types": "tsc -p tsconfig.build.json",
    "prepare": "npm run build:types",
    "smoke": "node ./hypaware-core/smoke/index.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1094.0",
    "@aws-sdk/credential-provider-ini": "3.973.5",
    "hyparquet": "1.26.2",
    "hyparquet-compressors": "1.1.1",
    "icebird": "0.8.15",
    "squirreling": "0.15.0"
  },
  "optionalDependencies": {
    "hyparquet-writer": "0.16.1",
    "hypvector": "0.2.2"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "typescript": "6.0.3"
  }
}

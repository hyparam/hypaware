{
  "schema_version": 1,
  "name": "@hypaware/claude",
  "version": "2.0.0",
  "description": "Anthropic Claude Code client adapter for HypAware. Registers the Anthropic upstream preset and exchange projector on the local AI gateway, configures Claude Code's settings.json to route through the gateway, writes session-context records into the plugin state directory for the projector to read, and ships helper skills.",
  "hypaware_api": "^1.0.0",
  "runtime": "node",
  "node_engine": ">=20",
  "entrypoint": "./src/index.js",
  "permissions": [
    "read_home",
    "write_home",
    "read_state",
    "read_claude_transcripts",
    "write_claude_settings"
  ],
  "requires": {
    "capabilities": {
      "hypaware.ai-gateway": "^2.0.0"
    }
  },
  "contributes": {
    "client": {
      "name": "claude",
      "skill_dir": ".claude/skills",
      "agent_dir": ".claude/agents",
      "attach_probe": {
        "format": "json",
        "settings_file": ".claude/settings.json",
        "marker_key": "_hypaware"
      },
      "required_upstreams": ["anthropic"]
    },
    "skills": [
      { "name": "hypaware-query", "clients": ["claude"] },
      { "name": "hypaware-reference", "clients": ["claude"] },
      { "name": "hypaware-ignore", "clients": ["claude"] },
      { "name": "hypaware-unignore", "clients": ["claude"] },
      { "name": "hypaware-privacy", "clients": ["claude"] },
      { "name": "hypaware-graph", "clients": ["claude"] },
      { "name": "hypaware-sensitive-scan", "clients": ["claude"] },
      { "name": "hypaware-ai-usage-report", "clients": ["claude"] },
      { "name": "hypaware-ai-adoption-report", "clients": ["claude"] },
      { "name": "hypaware-ai-improvement-report", "clients": ["claude"] },
      { "name": "hypaware-ai-security-report", "clients": ["claude"] },
      { "name": "hypaware-ai-spend-report", "clients": ["claude"] },
      { "name": "hypaware-report-to-html", "clients": ["claude"] },
      { "name": "hypaware-apply-report-changes", "clients": ["claude"] },
      { "name": "hypaware-apply-report-github-changes", "clients": ["claude"] }
    ],
    "agents": [
      { "name": "hypaware-analyst", "clients": ["claude"] }
    ],
    "init_presets": [
      {
        "name": "claude-and-otel-local",
        "summary": "Capture Claude Code + OTLP locally, export to Parquet under HYP_HOME/exports"
      }
    ],
    "config_sections": [
      {
        "section": "claude",
        "summary": "Claude adapter config, including the optional backfill-on-join policy { on_join, window_days }."
      }
    ]
  }
}
